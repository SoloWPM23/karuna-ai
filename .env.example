# =====================================================
# KarunaAI API - Environment Variables
# =====================================================
# Copy file ini ke .env dan isi nilainya

# =====================================================
# API Configuration
# =====================================================
# Aktifkan API key authentication
API_KEY_ENABLED=false

# API keys (pisahkan dengan koma untuk multiple keys)
# Generate dengan: python -c "import secrets; print('ka_' + secrets.token_urlsafe(32))"
API_KEYS=your_api_key_here

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_KEY=1000

# CORS - pisahkan origins dengan koma
ALLOWED_ORIGINS=*

# Debug mode (set ke false di production)
DEBUG=false


# =====================================================
# Groq API (S1 & S4)
# =====================================================
# Dapatkan dari https://console.groq.com/
GROQ_API_KEY=your_groq_api_key


# =====================================================
# Eleven Labs API (STT & TTS)
# =====================================================
# Dapatkan dari https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key


# =====================================================
# Model Paths (jangan ubah)
# =====================================================
EMOTION_MODEL_PATH=models/emotion_engine/final
CRISIS_MODEL_PATH=models/crisis_detector/final


# =====================================================
# Session Configuration
# =====================================================
# Session timeout dalam menit
SESSION_TIMEOUT=60

# Maksimum pesan per sesi
MAX_MESSAGES_PER_SESSION=100
